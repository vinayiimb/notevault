// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  // Pooled (pgbouncer) connection for normal app queries.
  url       = env("DATABASE_URL")
  // Direct connection, used only for running migrations (pooled
  // connections can't create the shadow database Prisma needs to diff
  // schema changes against).
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum EducationLevel {
  SCHOOL
  COLLEGE
}

enum ResourceType {
  NOTES
  PYQ
}

// e.g. "CBSE Class 12", "B.Com (Hons)", "BBA"
model Program {
  id        String         @id @default(cuid())
  level     EducationLevel
  name      String
  slug      String         @unique
  summary   String?
  createdAt DateTime       @default(now())

  terms Term[]
}

// e.g. "Semester 1" for college, or just "Full Year" for school
model Term {
  id        String   @id @default(cuid())
  programId String
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  name      String
  order     Int      @default(1)
  createdAt DateTime @default(now())

  subjects   Subject[]
  termPapers TermPaper[]

  @@unique([programId, order])
}

model Subject {
  id          String   @id @default(cuid())
  termId      String
  term        Term     @relation(fields: [termId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  createdAt   DateTime @default(now())

  resources Resource[]
  questions Question[]
  analysis  SubjectAnalysis?
  notes     SubjectNotes?

  @@unique([termId, slug])
}

// Admin-pasted, long-form compiled notes for a subject (markdown), rendered
// on the public subject page with its own styling — distinct from Resource
// rows of type NOTES, which are uploaded PDF files.
model SubjectNotes {
  id        String   @id @default(cuid())
  subjectId String   @unique
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  content   String
  theme     String   @default("sky")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// Cached result of analyzing a subject's uploaded PYQ papers: AI-compiled
// notes, the most-repeated questions across years, and a predicted paper.
// Regenerated on demand (not automatically) since it costs a real AI call.
model SubjectAnalysis {
  id                  String   @id @default(cuid())
  subjectId           String   @unique
  subject             Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  compiledNotes       String
  mostRepeatedJson    String // JSON-encoded array
  predictedPaperJson  String // JSON-encoded array
  sourceResourceCount Int
  generatedAt         DateTime @default(now())
}

model Resource {
  id             String       @id @default(cuid())
  subjectId      String
  subject        Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  type           ResourceType
  title          String
  year           Int?
  academicYear   String?
  fileUrl        String
  fileName       String
  fileSize       Int
  fileHash       String? // SHA-256 of the file bytes, used to reject duplicate uploads
  ocrText        String?      @db.Text
  ocrTextHash    String?
  sourceJsonName String?      @unique
  pageCount      Int?
  downloads      Int          @default(0)
  createdAt      DateTime     @default(now())
  batchId        String?
  batch          UploadBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  questions Question[]

  @@index([fileHash])
  @@index([batchId])
}

// A single combined paper covering every subject for one Program+Semester
// at once (as opposed to a Resource, which always belongs to one Subject) —
// e.g. a scanned "B.Com (H) Semester 1" booklet that bundles all subjects'
// question papers together instead of being split per subject. Shown on
// that term's public page alongside its per-subject resources.
model TermPaper {
  id           String       @id @default(cuid())
  termId       String
  term         Term         @relation(fields: [termId], references: [id], onDelete: Cascade)
  year         Int?
  academicYear String?
  fileUrl      String
  fileName     String
  fileSize     Int
  fileHash     String?
  batchId      String?
  batch        UploadBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())

  @@index([fileHash])
  @@index([batchId])
}

// One row per "Upload N files" click in Bulk Upload — lets the admin later
// browse back through what was uploaded together and fix a mistake (wrong
// year/subject/type) without having to hunt for the resource elsewhere.
model UploadBatch {
  id         String      @id @default(cuid())
  createdAt  DateTime    @default(now())
  resources  Resource[]
  termPapers TermPaper[]
}

// A row an admin either couldn't assign a subject to, or that failed to
// upload, kept around (with the original file) so it isn't silently lost —
// visible on /admin/failed-uploads for the admin to fix and retry later.
model FailedUpload {
  id        String       @id @default(cuid())
  fileName  String
  title     String
  type      ResourceType
  year      Int?
  reason    String
  fileUrl   String?
  fileSize  Int?
  fileHash  String? // lets the admin see if this is a duplicate of an already-uploaded resource
  createdAt DateTime     @default(now())

  @@index([fileHash])
}

// Individual PYQ question, optionally linked back to the paper it appeared in.
// isRepeated + repeatCount + years power the "most repeated questions" feature.
model Question {
  id           String    @id @default(cuid())
  subjectId    String
  subject      Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  resourceId   String?
  resource     Resource? @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  questionText String
  answerText   String
  marks        Int?
  isRepeated   Boolean   @default(false)
  repeatCount  Int       @default(1)
  years        String? // comma-separated list of years this question appeared, e.g. "2021,2022,2024"
  createdAt    DateTime  @default(now())
}

// Singleton row (id is always "singleton") for the small set of homepage
// text fields an admin can safely edit without any risk of breaking a page.
model SiteSettings {
  id              String   @id @default("singleton")
  heroHeadline    String?
  heroSubtitle    String?
  heroImageUrl    String?
  currencyIconUrl String?
  updatedAt       DateTime @updatedAt
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
}

// Learned filename/title -> subject associations for Bulk Upload. When an
// admin manually assigns a subject to a paper the filename-matching heuristic
// couldn't place, we remember it (keyed by a normalized title with trailing
// paper numbers stripped) so future uploads with a similar title auto-match.
model SubjectMatchMemory {
  id        String   @id @default(cuid())
  key       String   @unique
  subjectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Learned course-guess -> Program associations for Consolidated Upload. When
// an admin assigns a course to a detected group (a folder name, or an
// extracted course name from a flat dump of filenames) that the fuzzy
// matcher couldn't place on its own, we remember it — keyed by the same
// minimal-noise, synonym-canonicalized token key used for grouping — so a
// future upload with a similarly-worded but differently-punctuated or
// abbreviated filename ("Pol. Science" vs "Political Science") matches
// instantly instead of needing the same course picked again.
model CourseMatchMemory {
  id        String   @id @default(cuid())
  key       String   @unique
  programId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Anonymous, login-free student identity — one row per browser (device
// cookie), not a real account. Powers the streak / oranges / leaderboard
// mechanic without adding a password-based sign-up flow.
model Student {
  id             String   @id @default(cuid())
  deviceId       String   @unique
  nickname       String?
  oranges        Int      @default(0)
  streak         Int      @default(0)
  lastActiveDate String? // "YYYY-MM-DD", used to compute streak continuation
  createdAt      DateTime @default(now())

  events OrangeEvent[]
}

model OrangeEvent {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount    Int
  reason    String // "daily_visit" | "resource_view" | "exam_kit_session"
  createdAt DateTime @default(now())
}
